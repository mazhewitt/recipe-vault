# Database configuration
DATABASE_URL=sqlite:recipe-vault.db

# Server configuration
BIND_ADDRESS=127.0.0.1:3000

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info,recipe_vault=debug

# AI configuration
# Providers: anthropic (default) or gemini
AI_PROVIDER=anthropic
# Optional; defaults to AI_PROVIDER when omitted
DIFFICULTY_PROVIDER=anthropic

# Set the key for whichever provider(s) you select.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# Chat model: needs strong multilingual support for native-language recipe search queries
AI_MODEL=claude-sonnet-4-6
# Difficulty assessment model: simple structured task (returns 1-5), haiku is sufficient and faster
DIFFICULTY_MODEL=claude-haiku-4-5

# Gemini example:
# AI_PROVIDER=gemini
# DIFFICULTY_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# AI_MODEL=gemini-2.5-pro
# DIFFICULTY_MODEL=gemini-2.5-flash

# Web authentication (optional - if not set, only API key auth works)
# This is the password family members enter to access the web chat
FAMILY_PASSWORD=your-family-password-here

# Web search is enabled automatically when uv is installed (uses DuckDuckGo, no API key required)
# "find me a recipe for X" will search in the native language of the dish's cuisine
